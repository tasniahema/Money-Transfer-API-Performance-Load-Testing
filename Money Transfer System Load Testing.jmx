          <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="BeanShell PostProcessor" enabled="true">
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">// Get Merchant Phone from JSON Extractor
String phone = vars.get(&quot;merchant_phone&quot;); 
if(phone == null || phone.equals(&quot;NOT_FOUND&quot;) || phone.isEmpty()){
    log.error(&quot;Merchant phone NOT FOUND!&quot;);
} else {
    log.info(&quot;Merchant PHONE = &quot; + phone);
    props.put(&quot;merchant_phone&quot;, phone); // Save as global property
}

// Get Merchant Email
String email = vars.get(&quot;merchant_email&quot;);
if(email == null || email.equals(&quot;NOT_FOUND&quot;) || email.isEmpty()){
    log.warn(&quot;Merchant email NOT FOUND!&quot;);
} else {
    log.info(&quot;Merchant EMAIL = &quot; + email);
    props.put(&quot;merchant_email&quot;, email); // Save as global property
}
}
