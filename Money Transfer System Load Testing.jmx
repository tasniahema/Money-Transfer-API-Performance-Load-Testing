            <stringProp name="script">String from = props.get(&quot;customer1_phone&quot;);
String to = props.get(&quot;merchant_phone&quot;);

String body = &quot;{&quot;
    + &quot;\&quot;from_account\&quot;:\&quot;&quot; + from + &quot;\&quot;,&quot;
    + &quot;\&quot;to_account\&quot;:\&quot;&quot; + to + &quot;\&quot;,&quot;
