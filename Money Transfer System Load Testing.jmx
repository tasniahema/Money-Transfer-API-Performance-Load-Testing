            <stringProp name="script">String from = props.get(&quot;customer1_phone&quot;);
String to = props.get(&quot;customer2_phone&quot;);

if(from == null){
    log.info(&quot;FROM PHONE IS NULL&quot;);
}

if(to == null){
    log.info(&quot;TO PHONE IS NULL&quot;);
}

String body = &quot;{&quot;
 + &quot;\&quot;from_account\&quot;:\&quot;&quot; + from + &quot;\&quot;,&quot;
 + &quot;\&quot;to_account\&quot;:\&quot;&quot; + to + &quot;\&quot;,&quot;
 + &quot;\&quot;amount\&quot;:10&quot;
 + &quot;}&quot;;

vars.put(&quot;sendBody&quot;, body);</stringProp>
