<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Money Transfer System Load Testing">
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
    </TestPlan>
    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables [Same as Environment ]">
        <collectionProp name="Arguments.arguments">
          <elementProp name="baseUrl" elementType="Argument">
            <stringProp name="Argument.name">baseUrl</stringProp>
            <stringProp name="Argument.value">mta.newroztech.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="AUTH-SECRET-KEY" elementType="Argument">
            <stringProp name="Argument.name">AUTH-SECRET-KEY</stringProp>
            <stringProp name="Argument.value">e97b4ca15fd2b3086c1e4af98b72d503</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="system_phone-number" elementType="Argument">
            <stringProp name="Argument.name">system_phone-number</stringProp>
            <stringProp name="Argument.value">SYSTEM</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="customer1_phone" elementType="Argument">
            <stringProp name="Argument.name">customer1_phone</stringProp>
            <stringProp name="Argument.value">015${__threadNum}${__Random(1000000,9999999)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="AUTH-SECRET-KEY-SYSTEM" elementType="Argument">
            <stringProp name="Argument.name">AUTH-SECRET-KEY-SYSTEM</stringProp>
            <stringProp name="Argument.value">b82439df1c92a7fe504bf23da918e6f1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="from_role" elementType="Argument">
            <stringProp name="Argument.name">from_role</stringProp>
            <stringProp name="Argument.value">Customer</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="to_role" elementType="Argument">
            <stringProp name="Argument.name">to_role</stringProp>
            <stringProp name="Argument.value">Merchant</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="type" elementType="Argument">
            <stringProp name="Argument.name">type</stringProp>
            <stringProp name="Argument.value">FIXED</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="value" elementType="Argument">
            <stringProp name="Argument.name">value</stringProp>
            <stringProp name="Argument.value">5</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="customer2_phone" elementType="Argument">
            <stringProp name="Argument.name">customer2_phone</stringProp>
            <stringProp name="Argument.value">015${__Random(10000000,99999999)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
